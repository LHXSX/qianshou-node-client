{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "v3.0.0 默认能力集：主窗口 + 系统命令 + 自动更新 + 前端热更新远端 URL 信任",
  "windows": ["main"],
  "remote": {
    "urls": [
      "https://www.wujisuanli.com/*",
      "https://app.wujisuanli.com/*",
      "https://pidbai.com/*"
    ]
  },
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-set-focus",
    "core:webview:default",
    "core:menu:default",
    "core:tray:default",
    "shell:default",
    "shell:allow-open",
    "deep-link:default",
    "updater:default",
    "autostart:default",
    "autostart:allow-enable",
    "autostart:allow-disable",
    "autostart:allow-is-enabled"
  ]
}
